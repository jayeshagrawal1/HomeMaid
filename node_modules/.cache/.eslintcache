avbar.js",[],[],"D:\\DEV\\Project\\HomeMaid\\src\\components\\Error404.js",["176"],[],"D:\\DEV\\Project\\HomeMaid\\src\\components\\PaymentSuccess.js",["177","178"],[],"D:\\DEV\\Project\\HomeMaid\\src\\components\\Footer.js",[],[],"D:\\DEV\\Project\\HomeMaid\\src\\components\\Template.js",[],[],"D:\\DEV\\Project\\HomeMaid\\src\\components\\Feature.js",["179","180","181"],[],"D:\\DEV\\Project\\HomeMaid\\src\\components\\Popup.js",[],[],"D:\\DEV\\Project\\HomeMaid\\src\\components\\LoginForm.js",["182"],[],"D:\\DEV\\Project\\HomeMaid\\src\\components\\SignupForm.js",[],[],"D:\\DEV\\Project\\HomeMaid\\src\\reducer\\UseReducer.js",[],[],"D:\\DEV\\Project\\HomeMaid\\src\\pages\\Home.js",["183","184","185","186"],[],"import React from 'react'\r\nimport Feature from '../components/Feature'\r\nimport babysitter from '../images/icon_baby_care.jpg'\r\nimport cooks from '../images/icon_cook_chef.jpg'\r\nimport allrounder from '../images/icon-fd.jpg'\r\nimport domestichelp from '../images/icon_dom.jpg'\r\nimport { useNavigate } from 'react-router-dom'\r\n\r\nconst Home = () => {\r\n  const navigate=useNavigate();\r\n\r\n  function clickHandler(event)\r\n  {\r\n    navigate(\"/services\");\r\n  }\r\n  return (\r\n    <div className='flex flex-col  w-11/12 max-w-[1160px] py-4 mx-auto my-11' >\r\n        <div className=' text-white flex mb-11 gap-11'>\r\n          <div className=' flex flex-col items-start'>\r\n            <h1 className='text-5xl font-bold tracking-wide mt-2'>INDIA'S </h1>\r\n            <h1 className='text-5xl font-bold tracking-wide mt-2'>TRUSTED </h1>\r\n            <h1 className='text-5xl font-bold tracking-wide mt-2'> HOME MAKERS</h1>\r\n            <p className='text-xl tracking-wide mt-9 sm:w-[400px] leading-7'>HomeMaid is the simplest way to get your life in order with the right domestic help</p>\r\n            <button onClick={clickHandler}\r\n            className='text-white mt-9 rounded-[8px] font-medium uppercase p-3 border border-richblack-700 hover:bg-[#08111f] hover:text-yellow-50 transition-all duration-200'> Book Now</button>\r\n          </div>\r\n          <div className='md:flex md:flex-wrap gap-11 hidden bg-service '>\r\n            <img src={babysitter} className='h-[260px] w-[145px] hover:scale-105 transition-all duration-200'></img>\r\n            <img src={domestichelp} className='h-[260px] w-[145px] self-end -mb-4 hover:scale-105 transition-all duration-200'></img>\r\n            <img src={cooks} className='h-[260px] w-[145px] hover:scale-105 transition-all duration-200'></img>\r\n            <img src={allrounder} className='h-[260px] w-[145px] self-end -mb-4 hover:scale-105 transition-all duration-200'></img>\r\n          </div>\r\n        </div>\r\n        <Feature/>\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default Home","D:\\DEV\\Project\\HomeMaid\\src\\pages\\Services.js",[],[],"D:\\DEV\\Project\\HomeMaid\\src\\pages\\ContactUs.js",["187"],[],"import React, { useRef } from 'react'\r\nimport { toast } from 'react-hot-toast';\r\nimport flag from '../images/Group 19080.svg'\r\nimport { AiFillLinkedin, AiOutlineInstagram, AiFillFacebook, AiOutlineTwitter, AiFillYoutube } from 'react-icons/ai'\r\nimport emailjs from '@emailjs/browser';\r\n\r\n\r\nconst ContactUs = () => {\r\n\r\n    const form =useRef();\r\n\r\n    const sendEmail = (e) => {\r\n        e.preventDefault();\r\n    \r\n        emailjs.sendForm('service_pold6rj', 'template_lznhu7c', form.current, 'lXk9jWUXFp7c72CSH')\r\n          .then((result) => {\r\n              console.log(result.text);\r\n          }, (error) => {\r\n              console.log(error.text);\r\n          });\r\n\r\n          e.target.reset();\r\n      };\r\n\r\n\r\n    function submitHandler(event) {\r\n        sendEmail(event);\r\n        toast.success(\"we'll get back soon!\");        \r\n    }\r\n\r\n\r\n    return (\r\n        <div className='flex justify-around w-11/12 max-w-[1160px] py-8 mx-auto gap-x-12 gap-y-0 h-screen'>\r\n\r\n            <div className='flex flex-col w-11/12 max-w-[450px]'>\r\n\r\n                <p className='text-[#AFB2BF] text-xl'>Hey we are here!</p>\r\n                <p className='text-[#ebecf0] font-bold text-3xl mt-1'>Get in touch with us</p>\r\n\r\n                <form ref={form} onSubmit={submitHandler} className='flex flex-col w-full gap-y-4 mt-6'>\r\n\r\n                    {/* full Name  and mobile number*/}\r\n                    <div className='flex gap-x-4 mt-2'>\r\n                        <label className=\"w-full\">\r\n                            <p className='text-[0.875rem] text-richblack-5 mb-1 leading-[1.375rem]'>Full Name <sup className='text-pink-200'>*</sup></p>\r\n                            <input className='bg-richblack-800 rounded-[0.5rem] text-richblack-5 w-full p-[8px] '\r\n                                required\r\n                                type='text'\r\n                                name=\"user_name\"\r\n                                placeholder='Enter your Name'\r\n                            />\r\n                        </label>\r\n\r\n                        <label className='w-full relative'>\r\n                            <p className='text-[0.875rem] text-richblack-5 mb-1 leading-[1.375rem]'>Mobile Number <sup className='text-pink-200'>*</sup></p>\r\n                            <input className='bg-richblack-800 rounded-[0.5rem] text-richblack-5 w-full p-[8px] text-center'\r\n                                required\r\n                                type='text'\r\n                                name=\"user_mobile\"\r\n                                placeholder='9xxxxxxxxx'\r\n                            />\r\n                            <img className='absolute top-7' src={flag} />\r\n                        </label>\r\n                    </div>\r\n\r\n                    {/* email */}\r\n                    <label className='w-full mt-1'>\r\n                        <p className='text-[0.875rem] text-richblack-5 mb-1 leading-[1.375rem]'>Email Address <sup className='text-pink-200'>*</sup></p>\r\n                        <input className='bg-richblack-800 rounded-[0.5rem] text-richblack-5 w-full p-[8px]'\r\n                            required\r\n                            type='email'\r\n                            name='user_email'\r\n                            placeholder='Enter email address'\r\n                        />\r\n                    </label>\r\n\r\n                    {/* message */}\r\n                    <label className='w-full mt-1'>\r\n                        <p className='text-[0.875rem] text-richblack-5 mb-1 leading-[1.375rem]'>Message</p>\r\n                        <textarea className='bg-richblack-800 rounded-[0.5rem] text-richblack-5 w-full p-[8px]'\r\n                            name='message'\r\n                            placeholder='Enter your query'\r\n                        />\r\n                    </label>\r\n\r\n                    <button className='bg-yellow-50 rounded-[8px] font-medium text-richblack-900 px-[12px] py-[8px] mt-1'>Contact Us</button>\r\n                </form>\r\n\r\n                {/* links  */}\r\n                <div className='flex flex-wrap gap-6 mx-auto mt-10'>\r\n                    <AiFillLinkedin fontSize={30} fill='#AFB2BF' className='hover:scale-110 ease-in duration-300 cursor-pointer' />\r\n                    <AiOutlineInstagram fontSize={30} fill='#AFB2BF' className='hover:scale-110 ease-in duration-300 cursor-pointer' />\r\n                    <AiFillFacebook fontSize={30} fill='#AFB2BF' className='hover:scale-110 ease-in duration-300 cursor-pointer' />\r\n                    <AiFillYoutube fontSize={30} fill='#AFB2BF' className='hover:scale-110 ease-in duration-300 cursor-pointer' />\r\n                    <AiOutlineTwitter fontSize={30} fill='#AFB2BF' className='hover:scale-110 ease-in duration-300 cursor-pointer' />\r\n                </div>\r\n\r\n            </div>\r\n\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default ContactUs"